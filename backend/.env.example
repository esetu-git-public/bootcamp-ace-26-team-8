# --------------------------------------------------------------------------- #
# Loan Default Prediction System — Backend (FastAPI) environment variables
#
# Copy this file to `.env` in the `backend/` directory for local
# development. NEVER commit a real `.env` file with actual secrets —
# only this `.env.example` template belongs in version control.
#
# In deployment, these are set directly as Render environment variables
# (see backend/render.yaml) rather than via a committed .env file.
# --------------------------------------------------------------------------- #

# --- General ---
# Distinguishes dev/staging/production behavior; disables /docs, /redoc,
# and /openapi.json when set to "production" (see app/main.py).
ENVIRONMENT=development

# Controls verbosity of structured logging (app/core/logging.py).
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Supabase ---
# Backend's Supabase client initialization URL.
SUPABASE_URL=https://fqnzcwdnqsgefgsqfujy.supabase.co

# Privileged server-side Supabase key for reads/writes.
# NEVER expose this to the frontend — service role only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZxbnpjd2RucXNnZWZnc3FmdWp5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzkyODM5MywiZXhwIjoyMDk5NTA0MzkzfQ.di1MsPl1e_1GqN9GbKbIRqH66TT2pWYFr9vjubwjvnw

# Secret used to verify JWTs issued by Supabase Auth (static-secret path,
# currently the only verification path implemented in app/core/security.py).


# Reserved for future JWKS-based verification; declared but not yet
# consumed by app/core/security.py (which uses the static secret above).
SUPABASE_JWKS_URL=https://fqnzcwdnqsgefgsqfujy.supabase.co/auth/v1/.well-known/jwks.json

SUPABASE_ISSUER=
JWT_ALLOWED_ALGORITHMS=ES256,RS256
JWKS_CACHE_TTL_SECONDS=3600

# --- ML Model ---
# Path to loan_pipeline.pkl, relative to the backend/ working directory.
# Assumes the repository's default layout: ml/ as a sibling of backend/.
MODEL_PATH=../ml/models/loan_pipeline.pkl

# --- CORS ---
# Comma-separated list of origins allowed to call the API. Restricts
# which frontend origin(s) may access the backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth / Security ---
# Algorithm used to verify Supabase-issued JWTs.
JWT_ALGORITHM=HS256

# Expected 'aud' claim on Supabase Auth JWTs (Supabase's default).
ACCESS_TOKEN_AUDIENCE=authenticated